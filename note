        hydra/launcher=submitit_slurm \
        model=qwen3_4b,qwen3_8b_thinking,qwen3_235b_a22b,qwen3_32b \
        task_filter=mcq,numeric \
        num_frames=4 \
        slurm=hgpu_batch
